# .gitignore

# Dependencies
node_modules/
package-lock.json

# Environment variables
.env
.env.local
.env.*.local

# Logs
logs/
*.log
npm-debug.log*
src/logs/*.log

# Uploads
src/uploads/qrcodes/*
src/uploads/photos/*
!src/uploads/qrcodes/.gitkeep
!src/uploads/photos/.gitkeep

# OS Files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Build
dist/
build/

# Testing
coverage/
.nyc_output/

# Temporary files
*.tmp
temp/
# InsForge & AI agent skills
.insforge
.agent
.agents
.augment
.claude
.cline
.github/copilot*
.kilocode
.qoder
.qwen
.roo
.trae
.windsurf
